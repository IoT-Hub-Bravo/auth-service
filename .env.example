# ─── Docker Compose ───────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=auth-service
# Tells Docker Compose where to find the compose file so you can run
# `docker compose up --build` from the repo root without the -f flag.
COMPOSE_FILE=compose/standalone.yml

# ─── Django ───────────────────────────────────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_SECRET_KEY_DO_NOT_USE_IN_PRODUCTION
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
# DB_HOST=auth-db  ← use this when running via Docker Compose
# DB_HOST=localhost  ← use this for local runs without Docker
DB_HOST=auth-db
DB_PORT=5432
DB_NAME=auth_db
DB_USER=auth_user
DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Gunicorn ─────────────────────────────────────────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=30

# ─── Compose port mapping ─────────────────────────────────────────────────────
AUTH_SERVICE_PORT=8001

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Key files live in secrets/ (git-ignored). Generate them once:
#   openssl genrsa -out secrets/jwt_private.pem 2048
#   openssl rsa -in secrets/jwt_private.pem -pubout -out secrets/jwt_public.pem
#
# Inside Docker Compose the secrets/ dir is mounted at /run/secrets/:
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_KEY_ID=auth-service-key-1

# ─── Dev user seeding ─────────────────────────────────────────────────────────
# Set ALLOW_SETUP_ADMIN=true to auto-seed users on container startup.
# The command is idempotent — safe to leave enabled for local dev.
# NEVER set to true in production.
ALLOW_SETUP_ADMIN=false

# Superuser — required when ALLOW_SETUP_ADMIN=true
DEV_SUPERUSER_USERNAME=superadmin
DEV_SUPERUSER_EMAIL=superadmin@example.com
DEV_SUPERUSER_PASSWORD=CHANGE_ME

# role=admin seed user
DEV_ADMIN_USERNAME=admin_user
DEV_ADMIN_EMAIL=admin_user@example.com
DEV_ADMIN_PASSWORD=CHANGE_ME

# role=client seed user
DEV_CLIENT_USERNAME=client_user
DEV_CLIENT_EMAIL=client_user@example.com
DEV_CLIENT_PASSWORD=CHANGE_ME
